# ─────────────────────────────────────────────────────────────
# Payload CMS v3 (MongoDB)
# ─────────────────────────────────────────────────────────────
PAYLOAD_SECRET=your-secret-key-here-min-32-chars
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/probars

# ─────────────────────────────────────────────────────────────
# WooCommerce Store API
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_WOOCOMMERCE_URL=https://yourshop.com
WOOCOMMERCE_URL=https://yourshop.com
WOOCOMMERCE_CONSUMER_KEY=ck_live_xxxxxxxxxxxxxxxxxxxx
WOOCOMMERCE_CONSUMER_SECRET=cs_live_xxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# Revalidation
# ─────────────────────────────────────────────────────────────
REVALIDATE_SECRET=your-revalidation-secret-here

# ─────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yoursite.com
NODE_ENV=production
PORT=3000
