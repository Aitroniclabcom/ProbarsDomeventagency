# Payload CMS
PAYLOAD_SECRET=your-secret-min-32-chars

# Database — Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# WooCommerce — WOOCOMMERCE_URL must be the WordPress store (e.g. https://shop.domeventagency.com).
# Card payments use WooCommerce Stripe on that store — no separate Stripe keys needed in Next.js.
# Optional: override gateway id if your plugin uses a non-default slug (default auto-detected: stripe, woocommerce_payments).
# WOOCOMMERCE_STRIPE_GATEWAY_ID=stripe
WOOCOMMERCE_URL=https://your-wordpress-store.com
NEXT_PUBLIC_WOOCOMMERCE_URL=https://your-wordpress-store.com
WOOCOMMERCE_CONSUMER_KEY=ck_xxx
WOOCOMMERCE_CONSUMER_SECRET=cs_xxx

# App
NEXT_PUBLIC_SITE_URL=https://domeventagency.com

# Email / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
CONTACT_EMAIL=info@domeventagency.com

# Optional — only if you add custom Stripe webhooks on the Next.js app (not required for WooCommerce Stripe checkout)
# STRIPE_SECRET_KEY=sk_live_xxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# Admin
ADMIN_PASSWORD=your_secure_admin_password
SESSION_SECRET=your_random_session_secret

# Optional — only if using apps/web (separate storefront)
# PAYLOAD_URL=
# NEXT_PUBLIC_PAYLOAD_URL=
# REVALIDATE_SECRET=
